# Copy to `.env` (this file is gitignored) and fill in values for your environment.
#
# Notes:
# - This repo loads `.env` via `ai_scientist.project_env.load_project_env()` using `os.environ.setdefault`,
#   meaning shell-exported env vars still override `.env`.
# - Never commit real API keys.
#
# ---------------------------------------------------------------------------
# OpenAI / OpenAI-compatible routing
# ---------------------------------------------------------------------------
#
# If you use an OpenAI-compatible gateway (recommended when routing `gpt-5.4` via your own endpoint):
# OPENAI_COMPATIBLE_BASE_URL=https://your-gateway.example.com/v1
# OPENAI_COMPATIBLE_API_KEY=YOUR_KEY_HERE
#
# If you want to use OpenAI directly, set:
# OPENAI_API_KEY=YOUR_KEY_HERE
#
# MiniMax (used when model name starts with `minimax/` OR when the model leaf starts with `MiniMax-`):
# MINIMAX_API_KEY=YOUR_MINIMAX_KEY_HERE
# Optional:
# MINIMAX_REGION=global  # or: cn
# MINIMAX_BASE_URL=https://api.minimax.io/v1
#
# Optional context controls (used by ai_scientist/openai_compatible.py):
AI_SCIENTIST_CONTEXT_TOKENS=200000
AI_SCIENTIST_MAX_OUTPUT_TOKENS=8192
#
# ---------------------------------------------------------------------------
# Literature search backend (citations)
# ---------------------------------------------------------------------------
#
# Options: semantic_scholar | openalex
AI_SCIENTIST_LITERATURE_BACKEND=semantic_scholar
#
# Semantic Scholar (Graph API):
# S2_API_KEY=YOUR_S2_KEY_HERE
#
# OpenAlex:
# OPENALEX_API_KEY=YOUR_OPENALEX_KEY_HERE
# OPENALEX_MAILTO=you@example.com
#
# ---------------------------------------------------------------------------
# Vast.ai execution (when exec.backend=vast)
# ---------------------------------------------------------------------------
#
# VAST_API_KEY=YOUR_VAST_KEY_HERE
# VAST_SSH_PRIVATE_KEY_PATH=/abs/path/to/id_rsa
# VAST_SSH_PUBLIC_KEY_PATH=/abs/path/to/id_rsa.pub
#
# Optional overrides (bfts_config.yaml reads these via ${oc.env:...}):
# AI_SCIENTIST_EXEC_BACKEND=vast
# AI_SCIENTIST_EXEC_TIMEOUT=3600
# AI_SCIENTIST_VAST_EXISTING_INSTANCE_ID=
# AI_SCIENTIST_VAST_OFFER_ID=
# AI_SCIENTIST_VAST_AUTO_DESTROY=true
# AI_SCIENTIST_VAST_READINESS_TIMEOUT=900
# AI_SCIENTIST_VAST_SETUP_TIMEOUT=1800
#
# Vast search filters:
# AI_SCIENTIST_VAST_SEARCH_LIMIT=25
# AI_SCIENTIST_VAST_SEARCH_ORDER=dph_total
# AI_SCIENTIST_VAST_SEARCH_TYPE=on-demand
# AI_SCIENTIST_VAST_SEARCH_VERIFIED=true
# AI_SCIENTIST_VAST_SEARCH_RENTABLE=true
# AI_SCIENTIST_VAST_SEARCH_RENTED=false
# AI_SCIENTIST_VAST_SEARCH_NUM_GPUS=1
# AI_SCIENTIST_VAST_SEARCH_RELIABILITY_MIN=0.95
# AI_SCIENTIST_VAST_SEARCH_INET_UP_MIN=100
# AI_SCIENTIST_VAST_SEARCH_DIRECT_PORT_COUNT_MIN=1
#
# ---------------------------------------------------------------------------
# WSL SSH execution (when exec.backend=wsl_ssh)
# ---------------------------------------------------------------------------
#
# This is the recommended default for local development.
AI_SCIENTIST_EXEC_BACKEND=wsl_ssh
AI_SCIENTIST_EXEC_TIMEOUT=3600
#
# Required:
# AI_SCIENTIST_WSL_SSH_HOST=YOUR_WSL_SSH_HOST
# AI_SCIENTIST_WSL_SSH_USER=YOUR_SSH_USER
# AI_SCIENTIST_WSL_SSH_PRIVATE_KEY_PATH=/abs/path/to/ssh_private_key
#
# Optional:
# AI_SCIENTIST_WSL_SSH_PORT=22
# AI_SCIENTIST_WSL_SSH_HOST_CANDIDATES=host1,host2
# AI_SCIENTIST_WSL_DISTRO=Ubuntu
# AI_SCIENTIST_WSL_REMOTE_ROOT=/home/your_user/auctrace
# AI_SCIENTIST_WSL_VENV_PATH=/home/your_user/venv
#
# ---------------------------------------------------------------------------
# Models (BFTS stage runtime; used in bfts_config.yaml via ${oc.env:...})
# ---------------------------------------------------------------------------
#
AI_SCIENTIST_NUM_WORKERS=4
#
# Recommended role split:
# - `gpt-5.4`: harder reasoning / planning / reviewing (must support long context + VLM for image roles)
# - `minimax/MiniMax-M2.7`: medium model for heavy/tedious coding tasks
AI_SCIENTIST_MODEL_CODE=minimax/MiniMax-M2.7
AI_SCIENTIST_MODEL_FEEDBACK=gpt-5.4
AI_SCIENTIST_MODEL_VLM_FEEDBACK=gpt-5.4
AI_SCIENTIST_MODEL_SUMMARY=gpt-5.4
AI_SCIENTIST_MODEL_SELECT_NODE=gpt-5.4
AI_SCIENTIST_MODEL_REPORT=gpt-5.4
#
# Optional fallbacks (leave empty or comment out if unused):
# AI_SCIENTIST_MODEL_CODE_FALLBACK=
# AI_SCIENTIST_MODEL_FEEDBACK_FALLBACK=
# AI_SCIENTIST_MODEL_VLM_FEEDBACK_FALLBACK=
# AI_SCIENTIST_MODEL_SUMMARY_FALLBACK=
# AI_SCIENTIST_MODEL_SELECT_NODE_FALLBACK=
# AI_SCIENTIST_MODEL_REPORT_FALLBACK=
#
# ---------------------------------------------------------------------------
# Postprocess / writeup / review defaults
# ---------------------------------------------------------------------------
#
# Used by launch_scientist_bfts.py and postprocess_existing_run.py as argparse defaults:
AI_SCIENTIST_MODEL_AGG_PLOTS=minimax/MiniMax-M2.7
AI_SCIENTIST_MODEL_CITATION=minimax/MiniMax-M2.7
AI_SCIENTIST_MODEL_WRITEUP=gpt-5.4
AI_SCIENTIST_MODEL_WRITEUP_SMALL=gpt-5.4
AI_SCIENTIST_MODEL_REVIEW=gpt-5.4
#
AI_SCIENTIST_NUM_CITE_ROUNDS=20
AI_SCIENTIST_PLOT_REFLECTIONS=5
#
# ---------------------------------------------------------------------------
# Launcher defaults (optional)
# ---------------------------------------------------------------------------
#
# AI_SCIENTIST_WRITEUP_TYPE=icbinb
# AI_SCIENTIST_IDEAS_PATH=ai_scientist/ideas/i_cant_believe_its_not_better.json
# AI_SCIENTIST_IDEA_IDX=0
# AI_SCIENTIST_ATTEMPT_ID=0
# AI_SCIENTIST_BFTS_CONFIG_PATH=bfts_config.yaml
# AI_SCIENTIST_WRITEUP_RETRIES=3
#
# Ideation defaults (optional):
AI_SCIENTIST_MODEL_IDEATION=gpt-5.4
# AI_SCIENTIST_MAX_NUM_GENERATIONS=1
# AI_SCIENTIST_WORKSHOP_FILE=ai_scientist/ideas/i_cant_believe_its_not_better.md
# AI_SCIENTIST_IDEATION_REFLECTIONS=5
# AI_SCIENTIST_WRITEUP_REFLECTIONS=3
# AI_SCIENTIST_WRITEUP_PAGE_LIMIT=4
